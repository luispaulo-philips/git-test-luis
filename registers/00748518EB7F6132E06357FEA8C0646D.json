"data_type":"CLOB",
"old_value":null,
"new_value":"CREATE OR REPLACE procedure html_abrir_conta_terceiro(\tcd_perfil_p\tnumber,\n\t\t\t\t\t\t\t\t\t\tnm_usuario_p\tvarchar2,\n\t\t\t\t\t\t\t\t\t\tcd_estabelecimento_p\tnumber,\n\t\t\t\t\t\t\t\t\t\tmes_ref_p date\t) is\n\nds_terceiros_w\t\tvarchar2(2000);\nie_restringe_ter_w\tvarchar2(1);\nds_terc_liberados_w\tvarchar2(2000) := null;\n\nbegin\n\nObter_Param_Usuario(907, 43, cd_perfil_p, nm_usuario_p, cd_estabelecimento_p, ds_terceiros_w);\nObter_Param_Usuario(907, 53, cd_perfil_p, nm_usuario_p, cd_estabelecimento_p, ie_restringe_ter_w);\n\nif ((ie_restringe_ter_w = 'S') and (nvl(trim(ds_terceiros_w), 'XPTO') <> 'XPTO')) then\n\tds_terc_liberados_w\t:= ds_terceiros_w;\nend if;\n\nabrir_conta_terceiro(mes_ref_p, ds_terc_liberados_w);\n\nend html_abrir_conta_terceiro;\n\/" 
},
{"column_name":"DS_SCRIPT_CRIACAO_NEW",
"data_type":"CLOB",
"old_value":null,
"new_value":"CREATE OR REPLACE PROCEDURE HTML_ABRIR_CONTA_TERCEIRO (\n\tCD_PERFIL_P IN NUMBER, \n\tNM_USUARIO_P IN VARCHAR2, \n\tCD_ESTABELECIMENTO_P IN NUMBER, \n\tMES_REF_P IN DATE) IS \nBEGIN\n\tPABC_HTML_ABRIR_CONTA_T(CD_PERFIL_P, NM_USUARIO_P, CD_ESTABELECIMENTO_P, MES_REF_P);\nEND HTML_ABRIR_CONTA_TERCEIRO;\n\/" 
}
